# EC2 /opt/simple-erp/.env 로 복사 후 값 채우기.
# 절대 git 에 커밋하지 말 것 (.gitignore 가 .env 차단).

# ===== DB =====
DB_NAME=simple_erp
DB_PASSWORD=                 # 강한 무작위 (예: openssl rand -base64 24)

# ===== Backend =====
JWT_SECRET=                  # openssl rand -base64 64 (HS512 권장)
JWT_EXPIRATION=10080         # 분 단위 (기본 7일)
CORS_ALLOWED_ORIGINS=https://erp.example.com
APP_ADMIN_LOGIN_ID=admin
APP_ADMIN_PASSWORD=          # 일회용 — 첫 로그인 후 본인 변경

# ===== Spring 런타임 토글 (prod 권장값) =====
DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# ===== Caddy / TLS =====
# 도메인 -> Caddy 가 Let's Encrypt 로 자동 TLS / :80 -> HTTP only
SITE_ADDRESS=erp.example.com

# ===== System =====
TZ=Asia/Seoul

# ===== 이미지 태그 (deploy.yml 이 SHA 로 덮어씀) =====
BACKEND_IMAGE=ghcr.io/ladium1/simple-erp-backend:latest
WEB_IMAGE=ghcr.io/ladium1/simple-erp-web:latest

# ===== S3 백업 (backup-db.sh 용) =====
S3_BUCKET=                   # 예: simple-erp-backups
AWS_DEFAULT_REGION=ap-northeast-2

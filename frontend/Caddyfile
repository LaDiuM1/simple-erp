# SITE_ADDRESS 환경변수로 사이트 주소 지정.
#   - prod: SITE_ADDRESS=erp.example.com  (Caddy 가 Let's Encrypt 자동 TLS)
#   - local: SITE_ADDRESS=:80             (HTTP only — TLS 시도 안 함)

{$SITE_ADDRESS::80} {
    encode gzip

    # 백엔드 API + actuator 헬스체크 → backend:8080
    handle /api/* {
        reverse_proxy backend:8080
    }
    handle /actuator/health {
        reverse_proxy backend:8080
    }

    # SPA — index.html fallback
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }

    # 정적 자산 long-cache (Vite hash 파일명 가정)
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # index.html 은 no-cache (다음 빌드 즉시 반영)
    @html path / /index.html
    header @html Cache-Control "no-cache"
}
